{
  "$schema": "../../schemas/keyframe-job.schema.json",
  "acceptance": {
    "manual": [
      "exactly one eye visible",
      "short bob preserved",
      "jacket, tie, shorts, socks and boots preserved",
      "feet fully visible",
      "strict side profile",
      "pose reads as walk contact frame"
    ],
    "minimum_passing_variants": 3
  },
  "assets": {
    "boundary_mask": {
      "path": "../../assets/masks/ai46_walk_contact_boundary.png"
    },
    "contour": {
      "path": "../../assets/contours/ai46_walk_contact_canny.png"
    },
    "pose": {
      "path": "../../assets/poses/ai46_walk_contact_pose.png"
    }
  },
  "canvas": {
    "height": 768,
    "max_sequence_length": 128,
    "reference_max_area": 524288,
    "width": 512
  },
  "character": {
    "id": "ai46",
    "identity_primer": {
      "view": "front",
      "path": "../../assets/characters/ai46/views/front_v1.png"
    }
  },
  "conditions": [
    {
      "end": 0.55,
      "image": "pose",
      "name": "pose",
      "scale": 0.55,
      "start": 0.0,
      "type": "pose"
    },
    {
      "end": 0.4,
      "image": "contour",
      "name": "profile_contour",
      "residual_mask": "boundary_mask",
      "scale": 0.35,
      "start": 0.0,
      "type": "canny"
    }
  ],
  "id": "ai46.walk.contact.left.v1",
  "keyframe": {
    "action": "walk",
    "camera": "orthographic-side",
    "direction": "left",
    "phase": "contact"
  },
  "kind": "character-keyframe",
  "output": {
    "directory": "../../runs/keyframes/ai46/walk_contact/v1",
    "filename": "{id}__{variant}.png",
    "overwrite": false,
    "save_conditions": true,
    "save_contact_sheet": true
  },
  "pipeline": {
    "profile": "nunchaku-kontext-pose-quality"
  },
  "prompt": {
    "clip": "Same anime girl in a strict orthographic left-facing 90-degree side profile, platformer character side-view walking pose, exactly one eye visible, nose and chin in silhouette, short light-brown bob haircut, brown leather jacket, white shirt, blue tie, brown shorts, blue thigh-high socks, brown boots.",
    "t5": "Same anime girl in a strict orthographic left-facing 90-degree side profile, platformer character side-view walking pose, exactly one eye visible, nose and chin in silhouette, shoulders overlapping in depth, chest facing sideways. Keep the same short light-brown bob haircut, blue eyes, white shirt, blue tie, brown leather jacket, brown shorts, gloves, blue thigh-high socks, and brown boots. Clean plain neutral studio background.",
    "true_cfg_scale": 1.0
  },
  "sampling": {
    "guidance_scale": 2.5,
    "steps": 28
  },
  "schema_version": 1,
  "variants": [
    {
      "name": "seed_001",
      "seed": 1
    },
    {
      "name": "seed_002",
      "seed": 2
    },
    {
      "name": "seed_003",
      "seed": 3
    },
    {
      "name": "seed_004",
      "seed": 4
    }
  ]
}
