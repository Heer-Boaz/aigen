{
  "$defs": {
    "AcceptanceSpec": {
      "additionalProperties": false,
      "properties": {
        "manual": {
          "items": {
            "type": "string"
          },
          "title": "Manual",
          "type": "array"
        },
        "minimum_passing_variants": {
          "title": "Minimum Passing Variants",
          "type": "integer"
        }
      },
      "required": [
        "manual",
        "minimum_passing_variants"
      ],
      "title": "AcceptanceSpec",
      "type": "object"
    },
    "AssetSpec": {
      "additionalProperties": false,
      "properties": {
        "arm_hand_mask": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "boundary_mask": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "canny_lineart": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "contour": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "depth": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "filled_silhouette": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "full_silhouette_mask": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "gray": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "pose": {
          "$ref": "#/$defs/PathSpec"
        },
        "softedge": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "pose"
      ],
      "title": "AssetSpec",
      "type": "object"
    },
    "CanvasSpec": {
      "additionalProperties": false,
      "properties": {
        "height": {
          "title": "Height",
          "type": "integer"
        },
        "max_sequence_length": {
          "title": "Max Sequence Length",
          "type": "integer"
        },
        "reference_max_area": {
          "title": "Reference Max Area",
          "type": "integer"
        },
        "width": {
          "title": "Width",
          "type": "integer"
        }
      },
      "required": [
        "width",
        "height",
        "reference_max_area",
        "max_sequence_length"
      ],
      "title": "CanvasSpec",
      "type": "object"
    },
    "CharacterSpec": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "identity_primer": {
          "$ref": "#/$defs/IdentityPrimerSpec"
        }
      },
      "required": [
        "id",
        "identity_primer"
      ],
      "title": "CharacterSpec",
      "type": "object"
    },
    "ControlConditionSpec": {
      "additionalProperties": false,
      "properties": {
        "end": {
          "title": "End",
          "type": "number"
        },
        "image": {
          "title": "Image",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "residual_mask": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Residual Mask"
        },
        "scale": {
          "title": "Scale",
          "type": "number"
        },
        "start": {
          "title": "Start",
          "type": "number"
        },
        "type": {
          "enum": [
            "pose",
            "canny",
            "softedge",
            "depth",
            "gray"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "name",
        "type",
        "image",
        "scale",
        "start",
        "end"
      ],
      "title": "ControlConditionSpec",
      "type": "object"
    },
    "IdentityPrimerSpec": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "view": {
          "enum": [
            "front",
            "left_profile",
            "right_profile",
            "back"
          ],
          "title": "View",
          "type": "string"
        }
      },
      "required": [
        "view",
        "path"
      ],
      "title": "IdentityPrimerSpec",
      "type": "object"
    },
    "KeyframeSpec": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "title": "Action",
          "type": "string"
        },
        "camera": {
          "const": "orthographic-side",
          "title": "Camera",
          "type": "string"
        },
        "direction": {
          "enum": [
            "left",
            "right"
          ],
          "title": "Direction",
          "type": "string"
        },
        "phase": {
          "title": "Phase",
          "type": "string"
        }
      },
      "required": [
        "action",
        "phase",
        "direction",
        "camera"
      ],
      "title": "KeyframeSpec",
      "type": "object"
    },
    "OutputSpec": {
      "additionalProperties": false,
      "properties": {
        "directory": {
          "title": "Directory",
          "type": "string"
        },
        "filename": {
          "title": "Filename",
          "type": "string"
        },
        "overwrite": {
          "title": "Overwrite",
          "type": "boolean"
        },
        "save_conditions": {
          "title": "Save Conditions",
          "type": "boolean"
        },
        "save_contact_sheet": {
          "title": "Save Contact Sheet",
          "type": "boolean"
        }
      },
      "required": [
        "directory",
        "filename",
        "overwrite",
        "save_conditions",
        "save_contact_sheet"
      ],
      "title": "OutputSpec",
      "type": "object"
    },
    "PathSpec": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "title": "PathSpec",
      "type": "object"
    },
    "PipelineSpec": {
      "additionalProperties": false,
      "properties": {
        "profile": {
          "title": "Profile",
          "type": "string"
        }
      },
      "required": [
        "profile"
      ],
      "title": "PipelineSpec",
      "type": "object"
    },
    "PromptSpec": {
      "additionalProperties": false,
      "properties": {
        "clip": {
          "title": "Clip",
          "type": "string"
        },
        "negative": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Negative"
        },
        "t5": {
          "title": "T5",
          "type": "string"
        },
        "true_cfg_scale": {
          "title": "True Cfg Scale",
          "type": "number"
        }
      },
      "required": [
        "clip",
        "t5",
        "true_cfg_scale"
      ],
      "title": "PromptSpec",
      "type": "object"
    },
    "SamplingSpec": {
      "additionalProperties": false,
      "properties": {
        "guidance_scale": {
          "title": "Guidance Scale",
          "type": "number"
        },
        "steps": {
          "title": "Steps",
          "type": "integer"
        }
      },
      "required": [
        "steps",
        "guidance_scale"
      ],
      "title": "SamplingSpec",
      "type": "object"
    },
    "VariantSpec": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "seed": {
          "title": "Seed",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "seed"
      ],
      "title": "VariantSpec",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "acceptance": {
      "$ref": "#/$defs/AcceptanceSpec"
    },
    "assets": {
      "$ref": "#/$defs/AssetSpec"
    },
    "canvas": {
      "$ref": "#/$defs/CanvasSpec"
    },
    "character": {
      "$ref": "#/$defs/CharacterSpec"
    },
    "conditions": {
      "items": {
        "$ref": "#/$defs/ControlConditionSpec"
      },
      "title": "Conditions",
      "type": "array"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "keyframe": {
      "$ref": "#/$defs/KeyframeSpec"
    },
    "kind": {
      "const": "character-keyframe",
      "title": "Kind",
      "type": "string"
    },
    "output": {
      "$ref": "#/$defs/OutputSpec"
    },
    "pipeline": {
      "$ref": "#/$defs/PipelineSpec"
    },
    "prompt": {
      "$ref": "#/$defs/PromptSpec"
    },
    "sampling": {
      "$ref": "#/$defs/SamplingSpec"
    },
    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "variants": {
      "items": {
        "$ref": "#/$defs/VariantSpec"
      },
      "title": "Variants",
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "schema_version",
    "kind",
    "id",
    "pipeline",
    "character",
    "keyframe",
    "assets",
    "prompt",
    "canvas",
    "sampling",
    "conditions",
    "variants",
    "output",
    "acceptance"
  ],
  "title": "KeyframeJobSpec",
  "type": "object"
}
