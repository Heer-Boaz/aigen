{
  "$defs": {
    "AcceptanceSpec": {
      "additionalProperties": false,
      "properties": {
        "manual": {
          "items": {
            "type": "string"
          },
          "title": "Manual",
          "type": "array"
        },
        "minimum_passing_variants": {
          "title": "Minimum Passing Variants",
          "type": "integer"
        }
      },
      "required": [
        "manual",
        "minimum_passing_variants"
      ],
      "title": "AcceptanceSpec",
      "type": "object"
    },
    "CanvasSpec": {
      "additionalProperties": false,
      "properties": {
        "height": {
          "title": "Height",
          "type": "integer"
        },
        "max_sequence_length": {
          "title": "Max Sequence Length",
          "type": "integer"
        },
        "reference_max_area": {
          "title": "Reference Max Area",
          "type": "integer"
        },
        "width": {
          "title": "Width",
          "type": "integer"
        }
      },
      "required": [
        "width",
        "height",
        "reference_max_area",
        "max_sequence_length"
      ],
      "title": "CanvasSpec",
      "type": "object"
    },
    "CharacterViewSpec": {
      "additionalProperties": false,
      "properties": {
        "camera": {
          "enum": [
            "orthographic-front",
            "orthographic-side",
            "orthographic-back"
          ],
          "title": "Camera",
          "type": "string"
        },
        "name": {
          "enum": [
            "front",
            "left_profile",
            "right_profile",
            "back"
          ],
          "title": "Name",
          "type": "string"
        },
        "pose": {
          "title": "Pose",
          "type": "string"
        }
      },
      "required": [
        "name",
        "camera",
        "pose"
      ],
      "title": "CharacterViewSpec",
      "type": "object"
    },
    "ControlConditionSpec": {
      "additionalProperties": false,
      "properties": {
        "end": {
          "title": "End",
          "type": "number"
        },
        "image": {
          "title": "Image",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "residual_mask": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Residual Mask"
        },
        "scale": {
          "title": "Scale",
          "type": "number"
        },
        "start": {
          "title": "Start",
          "type": "number"
        },
        "type": {
          "enum": [
            "pose",
            "canny",
            "softedge",
            "depth"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "name",
        "type",
        "image",
        "scale",
        "start",
        "end"
      ],
      "title": "ControlConditionSpec",
      "type": "object"
    },
    "PathSpec": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "title": "PathSpec",
      "type": "object"
    },
    "PipelineSpec": {
      "additionalProperties": false,
      "properties": {
        "profile": {
          "title": "Profile",
          "type": "string"
        }
      },
      "required": [
        "profile"
      ],
      "title": "PipelineSpec",
      "type": "object"
    },
    "PromptSpec": {
      "additionalProperties": false,
      "properties": {
        "clip": {
          "title": "Clip",
          "type": "string"
        },
        "negative": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Negative"
        },
        "t5": {
          "title": "T5",
          "type": "string"
        },
        "true_cfg_scale": {
          "title": "True Cfg Scale",
          "type": "number"
        }
      },
      "required": [
        "clip",
        "t5",
        "true_cfg_scale"
      ],
      "title": "PromptSpec",
      "type": "object"
    },
    "SamplingSpec": {
      "additionalProperties": false,
      "properties": {
        "guidance_scale": {
          "title": "Guidance Scale",
          "type": "number"
        },
        "steps": {
          "title": "Steps",
          "type": "integer"
        }
      },
      "required": [
        "steps",
        "guidance_scale"
      ],
      "title": "SamplingSpec",
      "type": "object"
    },
    "SourceCharacterSpec": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "source_reference": {
          "$ref": "#/$defs/PathSpec"
        }
      },
      "required": [
        "id",
        "source_reference"
      ],
      "title": "SourceCharacterSpec",
      "type": "object"
    },
    "VariantSpec": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "seed": {
          "title": "Seed",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "seed"
      ],
      "title": "VariantSpec",
      "type": "object"
    },
    "ViewAssetsSpec": {
      "additionalProperties": false,
      "properties": {
        "boundary_mask": {
          "$ref": "#/$defs/PathSpec"
        },
        "contour": {
          "$ref": "#/$defs/PathSpec"
        },
        "pose": {
          "$ref": "#/$defs/PathSpec"
        }
      },
      "required": [
        "pose",
        "contour",
        "boundary_mask"
      ],
      "title": "ViewAssetsSpec",
      "type": "object"
    },
    "ViewOutputSpec": {
      "additionalProperties": false,
      "properties": {
        "bank_path": {
          "title": "Bank Path",
          "type": "string"
        },
        "canonical_path": {
          "title": "Canonical Path",
          "type": "string"
        },
        "directory": {
          "title": "Directory",
          "type": "string"
        },
        "filename": {
          "title": "Filename",
          "type": "string"
        },
        "overwrite": {
          "title": "Overwrite",
          "type": "boolean"
        },
        "save_conditions": {
          "title": "Save Conditions",
          "type": "boolean"
        },
        "save_contact_sheet": {
          "title": "Save Contact Sheet",
          "type": "boolean"
        }
      },
      "required": [
        "directory",
        "filename",
        "canonical_path",
        "bank_path",
        "overwrite",
        "save_conditions",
        "save_contact_sheet"
      ],
      "title": "ViewOutputSpec",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "title": "$Schema",
      "type": "string"
    },
    "acceptance": {
      "$ref": "#/$defs/AcceptanceSpec"
    },
    "assets": {
      "$ref": "#/$defs/ViewAssetsSpec"
    },
    "canvas": {
      "$ref": "#/$defs/CanvasSpec"
    },
    "character": {
      "$ref": "#/$defs/SourceCharacterSpec"
    },
    "conditions": {
      "items": {
        "$ref": "#/$defs/ControlConditionSpec"
      },
      "title": "Conditions",
      "type": "array"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "const": "character-view",
      "title": "Kind",
      "type": "string"
    },
    "output": {
      "$ref": "#/$defs/ViewOutputSpec"
    },
    "pipeline": {
      "$ref": "#/$defs/PipelineSpec"
    },
    "prompt": {
      "$ref": "#/$defs/PromptSpec"
    },
    "sampling": {
      "$ref": "#/$defs/SamplingSpec"
    },
    "schema_version": {
      "const": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "variants": {
      "items": {
        "$ref": "#/$defs/VariantSpec"
      },
      "title": "Variants",
      "type": "array"
    },
    "view": {
      "$ref": "#/$defs/CharacterViewSpec"
    }
  },
  "required": [
    "$schema",
    "schema_version",
    "kind",
    "id",
    "pipeline",
    "character",
    "view",
    "assets",
    "prompt",
    "canvas",
    "sampling",
    "conditions",
    "variants",
    "output",
    "acceptance"
  ],
  "title": "CharacterViewJobSpec",
  "type": "object"
}
